# Equilibris marketing site — environment variables
# Copy to .env and fill in (loaded by direnv via .envrc).
# The site is static; these only configure the public URL and telemetry.

# Public base URL of the deployed site
NEXT_PUBLIC_SITE_URL="https://equilibris.ai"

# Honeycomb / OpenTelemetry (traces). Ingest key — events only, not queries.
# Optional: without a key, traces simply don't export.
HONEYCOMB_API_KEY=
OTEL_SERVICE_NAME=equilibris-web
