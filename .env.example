SUPABASE_API_KEY=
SUPABASE_API_SECRET=

JWT_KEY_ID=
JWT_DISCOVERY_URL=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# This was inserted by `prisma init`:
# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use 
# the Prisma CLI with Bun to load environment variables from .env files: 
# https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, 
# SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: 
# https://pris.ly/d/connection-strings

# The following `prisma+postgres` URL is similar to the URL produced by running 
# a local Prisma Postgres server with the `prisma dev` CLI command, when not 
# choosing any non-default ports or settings. The API key, unlike the
# one found in a remote Prisma Postgres URL, does not contain any sensitive information.

# If using supepabase, grab the direct connection
DATABASE_DSN=

# Session pooler (port 5432) — used by Prisma CLI for migrations / db push.
DATABASE_DIRECT_DSN=

# Transactional email (Resend) — get a free key at https://resend.com
RESEND_API_KEY=
EMAIL_FROM="Equilibris <no-reply@email.equilibris.ai>"
EMAIL_REPLY_TO="support@equilibris.ai"
NEXT_PUBLIC_SITE_URL="https://equilibris.ai"

HONEYCOMB_DATASET=
HONEYCOMB_INGEST_API_KEY=
HONEYCOMB_CONFIG_API_KEY=
HONEYCOMB_CONFIG_API_TOKEN=
HONEYCOMB_API_KEY=

# Honeycomb / OpenTelemetry (traces). Ingest key — events only, not queries.
OTEL_SERVICE_NAME=
