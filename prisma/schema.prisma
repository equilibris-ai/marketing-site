// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// A captured marketing lead (waitlist signup). Email is verified
/// double-opt-in via a VerificationToken before we consider it confirmed.
model Lead {
  id         String              @id @default(cuid())
  email      String              @unique
  name       String?
  source     String              @default("waitlist")
  verifiedAt DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  tokens     VerificationToken[]

  @@map("leads")
}

/// One-time email-verification token tied to a Lead. `token` stores a SHA-256
/// hash of the value emailed to the user (the raw token is never persisted).
model VerificationToken {
  id        String    @id @default(cuid())
  token     String    @unique
  leadId    String
  lead      Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([leadId])
  @@map("verification_tokens")
}
