{
  "permissions": {
    "allow": [
      "Bash(awk:*)",
      "Bash(cd:*)",
      "Bash(mv:*)",
      "Bash(mkdir:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(curl:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(bundle exec rspec:*)",
      "Bash(bundle config get:*)",
      "Bash(pnpm run:*)",
      "Bash(npx:*)",
      "Bash(pnpm lint:*)",
      "Bash(gh run view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr checks:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git merge-base:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git branch --show current)",
      "Bash(git merge-base:*)",
      "Bash(node:*)",
      "Bash(timeout:*)",
      "Bash(gtimeout:*)",
      "Bash(python3:*)",
      "WebSearch",
      "WebFetch"
    ],
    "deny": ["Edit(db/structure.sql)", "Write(db/structure.sql)"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/lsp-reminder.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/nudge-gh-pr-body.sh",
            "if": "Bash(*gh pr create*)",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/nudge-gh-pr-body.sh",
            "if": "Bash(*gh pr edit*)",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/nudge-gh-pr-body.sh",
            "if": "Bash(*gh api*)",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/format-frontend.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/format-ruby.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pr-desc-nudge.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/symlink-worktree-env.sh",
            "if": "Bash(*git worktree add*)",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "codex@openai-codex": true,
    "ruby-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  }
}
